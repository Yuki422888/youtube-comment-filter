{
  "manifest_version": 3,
  "name": "YouTube Comment Filter",
  "version": "1.0",
  "description": "Filter abusive YouTube comments using AI",
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
